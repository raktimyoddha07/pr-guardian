# -----------------------------------------------------------------------------
# PR Guardian environment variables.
# Copy this file to `backend/.env` and fill in real values. Never commit .env.
# -----------------------------------------------------------------------------

# Application
APP_NAME=PR Guardian
DEBUG=false
# Comma-separated list of allowed CORS origins (the Next.js frontend / nginx).
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost"]

# Database (PostgreSQL 16 + pgvector). asyncpg driver for the async engine.
# In Docker, use: postgresql+asyncpg://postgres:postgres@postgres:5432/prguardian
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/prguardian
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Auth
# Generate a long random string, e.g. `python -c "import secrets;print(secrets.token_urlsafe(64))"`
SECRET_KEY=change-me-in-production-please-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- GitHub ---------------------------------------------------------------
# Option A: GitHub App (recommended for production).
# Create a GitHub App, generate a private key, save it as github-app.pem next to
# backend/, and install the app on the repos you want to guard.
GITHUB_APP_ID=
GITHUB_APP_SLUG=pr-guardian
GITHUB_APP_PRIVATE_KEY_PATH=./github-app.pem
# The shared secret configured on the webhook in GitHub settings.
GITHUB_WEBHOOK_SECRET=change-me-webhook-secret

# Option B: Personal Access Token fallback (handy for local dev only).
# If set, the GitHub client uses this directly and skips App auth entirely.
GITHUB_TOKEN=

# --- Vector DB ------------------------------------------------------------
# pgvector (default) stores embeddings in the Postgres `KnowledgeChunk` table;
# chromadb stores them in a separate ChromaDB collection per agent.
VECTOR_DB=pgvector
CHROMADB_HOST=localhost
CHROMADB_PORT=8001

# --- LLM ------------------------------------------------------------------
# Provider used by default when creating agents (per-agent override lives on the
# Agent row). ollama = local; gemini = Google Gemini Flash.
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_EMBED_MODEL=nomic-embed-text
# Embedding dimension (nomic-embed-text=768).
EMBEDDING_DIM=768

# --- RAG -------------------------------------------------------------------
RAG_CHUNK_TOKENS=512
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=8

# --- Ingestion -------------------------------------------------------------
INGESTION_MAX_FILES=5000
INGESTION_MAX_FILE_BYTES=524288
INGESTION_TEXT_EXTS=.py,.js,.ts,.tsx,.jsx,.go,.rs,.java,.kt,.rb,.php,.c,.cc,.cpp,.h,.hpp,.cs,.swift,.m,.mm,.scala,.clj,.ex,.exs,.erl,.hs,.ml,.lua,.pl,.r,.sh,.bash,.zsh,.fish,.ps1,.bat,.cmd,.yml,.yaml,.toml,.ini,.cfg,.conf,.json,.jsonc,.xml,.html,.css,.scss,.sass,.less,.vue,.svelte,.md,.rst,.txt,.sql,.graphql,.gql,.proto,.dockerfile,.env.example,.gitignore,.gitattributes

# --- Pipeline --------------------------------------------------------------
SPAM_THRESHOLD=0.75
FLAG_BAN_THRESHOLD=3
MAX_PR_DIFF_BYTES=524288

# --- Frontend (Docker) ------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# --- Docker Compose overrides -----------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=prguardian
DB_PORT=5432
BACKEND_PORT=8000
FRONTEND_PORT=3000
