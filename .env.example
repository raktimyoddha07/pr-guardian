# -----------------------------------------------------------------------------
# PR Guardian environment variables.
# Copy this file to `.env` and fill in real values. Never commit the real .env.
# -----------------------------------------------------------------------------

# Application
APP_NAME=PR Guardian
DEBUG=true
# Comma-separated list of allowed CORS origins (the Next.js frontend).
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# Database (PostgreSQL 16 + pgvector). asyncpg driver for the async engine.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/prguardian
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Auth
# Generate a long random string, e.g. `python -c "import secrets;print(secrets.token_urlsafe(64))"`
SECRET_KEY=change-me-in-production-please-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- GitHub ---------------------------------------------------------------
# Option A: GitHub App (recommended for production).
# Create a GitHub App, generate a private key, save it as github-app.pem next to
# backend/, and install the app on the repos you want to guard.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=./github-app.pem
# The shared secret configured on the webhook in GitHub settings.
GITHUB_WEBHOOK_SECRET=change-me-webhook-secret

# Option B: Personal Access Token fallback (handy for local dev only).
# If set, the GitHub client uses this directly and skips App auth entirely.
GITHUB_TOKEN=

# --- Vector DB ------------------------------------------------------------
# pgvector (default) stores embeddings in the Postgres `KnowledgeChunk` table;
# chromadb stores them in a separate ChromaDB collection per agent.
VECTOR_DB=pgvector
CHROMADB_HOST=localhost
CHROMADB_PORT=8001

# --- LLM ------------------------------------------------------------------
# Provider used by default when creating agents (per-agent override lives on the
# Agent row). ollama = local; gemini = Google Gemini Flash.
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
